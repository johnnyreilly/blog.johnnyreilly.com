{
  "name": "johnnyreilly.com",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "cd api && npm run build",
    "dev": "swa start http://localhost:3000 --run \"npm start\" --api-location api",
    "funcBuild": "swa start build --api-location api",
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "prebuild": "cd ../pre-post-processing && bun install && bun run pre-processing",
    "build": "tsc && cross-env WEBPACK_URL_LOADER_LIMIT=0 docusaurus build",
    "postbuild": "cd ../pre-post-processing && bun install && bun run post-processing",
    "knip": "knip",
    "lint": "eslint src",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@azure/static-web-apps-cli": "^2.0.8",
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/faster": "^3.9.2",
    "@docusaurus/plugin-ideal-image": "^3.9.2",
    "@docusaurus/plugin-pwa": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@svgr/webpack": "^8.1.0",
    "@swc/core": "^1.15.18",
    "clsx": "^2.1.1",
    "file-loader": "^6.2.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "url-loader": "^4.1.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "fontaine": "^0.8.0",
    "globals": "^17.0.0",
    "knip": "^6.3.0",
    "rehype-cloudinary-docusaurus": "^3.0.0",
    "simple-git": "^3.33.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
